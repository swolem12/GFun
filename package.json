{
  "name": "gfun",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace apps/desktop",
    "build:desktop": "npm run build --workspace apps/desktop",
    "dev:api": "uvicorn cad_api.main:app --reload --app-dir services/cad-api/src",
    "dev": "echo 'Run desktop and API in separate terminals: npm run dev:api && npm run dev:desktop'"
  }
}
